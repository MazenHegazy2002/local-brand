# ─── Platform Branding ─────────────────────────────────────────────────────────
# Set these to change the marketplace name without touching source code.
NEXT_PUBLIC_SITE_NAME="Brandy"          # Display name shown in titles, emails, JSON-LD
NEXT_PUBLIC_APP_URL="https://www.lolozozo.shop"  # Full canonical URL (no trailing slash)
NEXT_PUBLIC_SUPPORT_EMAIL="support@lolozozo.shop"
NEXT_PUBLIC_CONTACT_PHONE="+201094379477"
NEXT_PUBLIC_CONTACT_WHATSAPP="+201094379477"

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ─── Authentication (NextAuth) ─────────────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret" # Generate with: openssl rand -base64 32
NEXTAUTH_URL="https://your-domain.com"

# ─── OAuth Providers ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ─── Payments (PaySky PayForm Plus) ────────────────────────────────────────────
# Obtain MID, TID, and the merchant secret key from your PaySky onboarding contact.
# The secret is provided as hex (e.g. "62656164...5264") — do NOT base64-decode it.
# PAYSKY_ENV controls the Lightbox script URL: "test" (default) or "production".
PAYSKY_MERCHANT_ID=""
PAYSKY_TERMINAL_ID=""
PAYSKY_MERCHANT_SECRET=""
PAYSKY_ENV="test"

# ─── Payments (PayMob — optional) ──────────────────────────────────────────────
PAYMOB_API_KEY=""
PAYMOB_INTEGRATION_ID=""
PAYMOB_IFRAME_ID=""
PAYMOB_HMAC_SECRET=""

# ─── Payments (Fawry — optional) ───────────────────────────────────────────────
FAWRY_MERCHANT_CODE=""
FAWRY_SECURITY_KEY=""
FAWRY_BASE_URL="https://www.atfawry.com"

# ─── Image Hosting ─────────────────────────────────────────────────────────────
# Priority: Vercel Blob → Cloudinary → base64 data URL (dev only)
# Set BLOB_READ_WRITE_TOKEN for Vercel/Neon deployments, or the Cloudinary trio
# for other hosts. Both can be set; Blob takes priority when present.
BLOB_READ_WRITE_TOKEN=""

CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Email Service (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY="re_xxx"

# ─── Application URL ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ─── Secrets-at-rest encryption ────────────────────────────────────────────────
# 32-byte symmetric key used to encrypt seller bank account details and
# Payout bank-detail snapshots in the database. Provide as 64 hex chars or
# the base64 of 32 random bytes. Generate one with:
#   openssl rand -hex 32
# REQUIRED in production. If unset, those columns fall back to plain-text
# storage and the server logs a loud warning on every write.
BANK_ACCOUNT_SECRET=""

# ─── Tax registration (Egypt) ──────────────────────────────────────────────────
# Required by Egyptian invoice law. Without this, prod invoices are generated
# with the placeholder "XXX-XXX-XXX-DEV". Set before launch.
TAX_REGISTRATION_NUMBER=""

# ─── Backup ────────────────────────────────────────────────────────────────────
# How many days of automated daily backups to retain in Vercel Blob.
BACKUP_RETENTION_DAYS="30"

# ─── Cron secret ───────────────────────────────────────────────────────────────
# Optional Bearer token verified on /api/cron/* endpoints so external
# schedulers can trigger crons. Vercel Cron + the route handler sign
# requests with this; leave empty for local dev.
CRON_SECRET=""

# ─── Redis (guest carts + rate limiting) ───────────────────────────────────────
# Either a standard Redis URL OR Upstash REST credentials.
# If neither is set, an in-memory fallback is used (single-instance only).
REDIS_URL=""
REDIS_OFFLINE_QUEUE="false" # Set to "true" to queue Redis commands when offline
# -- OR Upstash --
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""   # Same value as VAPID_PUBLIC_KEY — exposed to client

# ─── Sentry (crash logging) ────────────────────────────────────────────────────
# Leave empty to disable Sentry entirely. SENTRY_AUTH_TOKEN is only needed
# at build time for source-map uploads (CI env var, not runtime).
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""    # CI/build only — do NOT set in production runtime

# ─── Uptime Monitoring ─────────────────────────────────────────────────────────
# Shared secret passed as ?secret=... or X-Webhook-Secret header by your monitor.
UPTIME_WEBHOOK_SECRET=""
# Email address to receive down/recovery alerts via Resend.
UPTIME_ALERT_EMAIL=""

# ─── SEO & Social ──────────────────────────────────────────────────────────────
# Google Search Console — paste the value from GSC → "Verify ownership" → HTML tag method
GOOGLE_SITE_VERIFICATION=""
# Facebook / Meta Domain Verification code
FACEBOOK_DOMAIN_VERIFICATION=""
# Twitter/X handle for twitter:creator meta tag (include the @)
NEXT_PUBLIC_TWITTER_HANDLE=""
# Canonical domain for cross-domain 301 redirect (no https://, e.g. "lolozozo.shop")
# When set, requests arriving on any OTHER domain redirect to this one.
CANONICAL_DOMAIN=""

# ─── Analytics & Marketing Plugins ─────────────────────────────────────────────
# Any variable left blank disables that plugin (zero-cost no-op).
NEXT_PUBLIC_GA_ID=""             # Google Analytics 4:  G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=""            # Google Tag Manager:  GTM-XXXXXXX
NEXT_PUBLIC_CRISP_WEBSITE_ID=""  # Crisp live chat
NEXT_PUBLIC_TAWK_PROPERTY_ID=""  # Tawk.to (pair with WIDGET_ID)
NEXT_PUBLIC_TAWK_WIDGET_ID=""
NEXT_PUBLIC_HOTJAR_ID=""         # Hotjar heatmaps/replays
NEXT_PUBLIC_META_PIXEL_ID=""     # Facebook / Instagram Pixel
