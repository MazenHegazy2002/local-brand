generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & ROLES
// ============================================

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String
  name             String
  role             Role      @default(BUYER)
  phone            String?
  avatarUrl        String?
  defaultAddressId String?
  loyaltyPoints    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  // Affiliate
  referredBySlug String?

  // Relations
  orders              Order[]
  addresses           Address[]
  reviews             Review[]
  wishlist            Wishlist[]
  emailVerified       DateTime?
  cart                CartItem[]
  sellerProfile       SellerProfile?
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  productQAs          ProductQA[]
  affiliate           Affiliate?
  promoUsages         PromoCodeUsage[]     @relation("BuyerPromoUsages")

  // Granular RBAC roles assigned to this user (in addition to the
  // coarse `role` enum above). See models AdminRole / UserAdminRole.
  adminRoles UserAdminRole[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime
  user    User     @relation(fields: [email], references: [email], onDelete: Cascade)

  @@unique([email, token])
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  street      String
  city        String
  governorate String
  postalCode  String?
  country     String   @default("Egypt")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// SELLERS & PORTAL
// ============================================

model SellerProfile {
  id             String       @id @default(uuid())
  userId         String       @unique
  storeName      String       @unique
  description    String?
  logoUrl        String?
  city           String?
  governorate    String?
  commissionRate Float        @default(0.15) // Platform takes 15%
  status         SellerStatus @default(PENDING_APPROVAL)
  bankAccount    String?
  balance        Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  payouts  Payout[]
}

enum SellerStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  BANNED
}

// ============================================
// CATALOGUE & INVENTORY
// ============================================

model Product {
  id          String  @id @default(uuid())
  sellerId    String
  categoryId  String
  title       String
  slug        String  @unique
  description String
  basePrice   Float // In EGP
  condition   String  @default("NEW")
  isFeatured  Boolean @default(false)
  weightGrams Int?
  published   Boolean @default(true)

  // Flash Sale
  flashSalePrice  Float?
  flashSaleEndsAt DateTime?
  flashSaleLimit  Int?

  // Local Verification
  countryOfOrigin String  @default("Egypt")
  isVerifiedLocal Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  seller       SellerProfile    @relation(fields: [sellerId], references: [id])
  category     Category         @relation(fields: [categoryId], references: [id])
  variants     ProductVariant[]
  images       ProductImage[]
  reviews      Review[]
  wishlistedBy Wishlist[]
  tags         Tag[]
  collections  Collection[]
  productQAs   ProductQA[]

  // Query-pattern indexes
  // Base browse: published + soft-delete guard, sorted by recency (default)
  @@index([published, deletedAt, createdAt])
  // Category page: narrow by category then apply the standard filters
  @@index([categoryId, published, deletedAt])
  // Seller hub / store page: all products for a seller
  @@index([sellerId, published, deletedAt])
  // Price sort / range filter
  @@index([basePrice])
  // Featured products section
  @@index([isFeatured, published, deletedAt])
  // Flash-sale filter (flashSaleEndsAt > now)
  @@index([flashSaleEndsAt])
}

model Category {
  id       String     @id @default(uuid())
  name     String     @unique
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("Subcategories", fields: [parentId], references: [id])
  children Category[] @relation("Subcategories")
  products Product[]
}

model Tag {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  products Product[]
}

model Collection {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  imageUrl    String?

  products Product[]
}

model ProductVariant {
  id         String  @id @default(uuid())
  productId  String
  // Internal stock-keeping unit chosen by the seller (or auto-generated
  // from the product slug when blank). Unique across the whole catalogue.
  sku        String  @unique
  // Optional Universal Product Code / EAN / GTIN — the public barcode on
  // the package. Sellers usually only have this if they carry branded
  // goods or rented numbers from GS1, so we never auto-generate it.
  upc        String?
  title      String // e.g. "Red - Medium"
  attributes String // JSON string for colors/sizes
  price      Float // Specific variant price overriding basePrice if needed
  stockCount Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([upc])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================
// CART & CHECKOUT
// ============================================

model CartItem {
  id         String   @id @default(uuid())
  userId     String
  variantId  String
  quantity   Int
  savedPrice Float
  addedAt    DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  minOrderValue Float?
  maxDiscount   Float?
  expiryDate    DateTime
  usageLimit    Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)

  orders Order[]
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ============================================
// ORDERS & LIFECYCLE
// ============================================

model Order {
  id                String        @id @default(uuid())
  userId            String?
  guestEmail        String?
  couponId          String?
  totalAmount       Float
  discountAmount    Float         @default(0)
  shippingFee       Float         @default(0)
  platformFee       Float         @default(0)
  sellerPayoutTotal Float         @default(0)
  status            OrderStatus   @default(PENDING_PAYMENT)
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(UNPAID)
  paymentId         String? // Gateway ID (Stripe/Paymob/PaySky SystemReference)
  paymentChannel    String? // Network used (e.g. Card / Tahweel / mVisa / Meeza)
  paymentNetworkRef String? // Network-side reference (e.g. PaySky NetworkReference)
  paymentMaskedPan  String? // Masked card / wallet account for receipts
  idempotencyKey    String?       @unique
  payoutProcessedAt DateTime? // Guard against double-payout

  // Customer checkout options
  orderNotes   String? // Optional buyer instructions (max 500 chars)
  giftWrapping Boolean @default(false)

  // Snapshots for historical integrity
  shippingAddressSnapshot String // JSON string of address

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Set when the order transitions to DELIVERED. Used to gate seller-earnings
  // escrow: payouts are held for ESCROW_DAYS (14) after delivery so any
  // returns/refunds don't leak through. Falls back to updatedAt when null
  // for orders delivered before this field was added.
  deliveredAt DateTime?

  user        User?           @relation(fields: [userId], references: [id])
  coupon      Coupon?         @relation(fields: [couponId], references: [id])
  items       OrderItem[]
  shipments   Shipment[]
  promoUsage  PromoCodeUsage?
  commissions Commission[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  variantId String

  // Snapshots
  productTitleSnapshot String
  sellerNameSnapshot   String
  priceAtPurchase      Float
  quantity             Int

  status OrderItemStatus @default(PENDING) // Can be refunded/returned individually

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  returnRequest ReturnRequest?
}

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum OrderItemStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  MOBILE_WALLET
  CASH_ON_DELIVERY
  PAYMOB
  FAWRY
  PAYSKY
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ============================================
// SHIPPING & TRANSACTIONS
// ============================================

model Shipment {
  id             String    @id @default(uuid())
  orderId        String
  trackingNumber String?
  courier        String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============================================
// TRUST & SOCIAL
// ============================================

model Review {
  id                 String   @id @default(uuid())
  userId             String
  productId          String
  rating             Int // 1-5
  comment            String?
  images             String[] @default([])
  verifiedPurchase   Boolean  @default(false)
  sellerResponseText String?
  createdAt          DateTime @default(now())

  // Moderation. When REVIEWS_AUTO_PUBLISH is off, new reviews land here
  // with status=PENDING and only become visible after admin approval.
  // status=HIDDEN keeps the row but stops it being read publicly (used
  // for spam, abuse, or post-publish takedowns).
  status         ReviewStatus @default(PUBLISHED)
  flaggedReason  String?
  flaggedAt      DateTime?
  flaggedBy      String? // admin user id
  moderationNote String?

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

enum ReviewStatus {
  PENDING // awaiting moderator
  PUBLISHED // visible
  HIDDEN // soft-removed
  REJECTED // moderator rejected outright
}

// ============================================
// PRODUCT Q&A
// ============================================

model ProductQA {
  id         String    @id @default(uuid())
  productId  String
  userId     String
  question   String
  answer     String?
  answererId String?
  answeredAt DateTime?
  createdAt  DateTime  @default(now())

  // Moderation — same approach as Review. The QA_AUTO_PUBLISH setting
  // controls whether answers are visible immediately or queue for admin.
  status         QAStatus  @default(PUBLISHED)
  flaggedReason  String?
  flaggedAt      DateTime?
  flaggedBy      String?
  moderationNote String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([status, createdAt])
}

enum QAStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
}

// ============================================
// SYSTEM & AUDIT
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payout {
  id            String       @id @default(uuid())
  sellerId      String
  amount        Float
  status        PayoutStatus @default(PENDING)
  bankDetails   String?
  transactionId String?
  processedAt   DateTime?
  createdAt     DateTime     @default(now())

  seller SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
}

model ReturnRequest {
  id          String       @id @default(uuid())
  orderItemId String       @unique
  reason      String
  details     String?
  status      ReturnStatus @default(PENDING)
  adminNotes  String?
  createdAt   DateTime     @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model AuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String // e.g. "BANNED_SELLER"
  targetId  String?
  details   String?
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])
}

model SystemSettings {
  key         String   @id // e.g. "VAT_RATE", "COMMISSION_BASE"
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Wishlist {
  userId    String
  productId String
  addedAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
}

// ============================================
// DISPUTES
// ============================================

model Dispute {
  id            String        @id @default(uuid())
  orderId       String
  orderItemId   String?
  buyerId       String
  sellerId      String?
  reason        String
  description   String?
  status        DisputeStatus @default(OPEN)
  resolution    String?
  resolvedAt    DateTime?
  caseReference String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([buyerId])
  @@index([status])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

// ============================================
// CHAT / CONVERSATIONS
// ============================================

model Conversation {
  id        String             @id @default(uuid())
  userId    String
  productId String?
  orderId   String?
  status    ConversationStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  messages Message[]

  @@index([userId])
  @@index([status])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  role           String   @default("USER")
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum ConversationStatus {
  ACTIVE
  CLOSED
}

// ============================================
// SUPPORT TICKETS
// ============================================

model SupportTicket {
  id         String       @id @default(uuid())
  ticketId   String       @unique // Short human-readable reference
  userId     String?
  name       String
  email      String
  subject    String
  category   String       @default("general")
  message    String
  status     TicketStatus @default(OPEN)
  priority   String       @default("normal")
  adminReply String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ============================================
// CMS: HOMEPAGE BANNERS
// ============================================

// ============================================
// AFFILIATE PROGRAM
// ============================================

enum AffiliateStatus {
  PENDING
  ACTIVE
  PAUSED
  BANNED
  REJECTED
}

enum AffiliateTier {
  STARTER
  SILVER
  GOLD
  PLATINUM
}

enum AffiliateCommissionStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

enum AffiliateBonusType {
  REFERRER_SIGNUP
  JOINER_SIGNUP
}

enum AffiliateBonusStatus {
  PENDING
  ACTIVE
  USED
  EXPIRED
}

enum AffiliatePayoutStatus {
  REQUESTED
  PROCESSING
  PAID
  REJECTED
}

enum AffiliatePayoutMethod {
  VODAFONE_CASH
  ORANGE_MONEY
  ETISALAT_CASH
  INSTAPAY
  BANK_TRANSFER
}

model Affiliate {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  promoCode    String @unique
  referralSlug String @unique

  status AffiliateStatus @default(PENDING)
  tier   AffiliateTier   @default(STARTER)

  customCommissionPct Decimal? @db.Decimal(5, 2)
  customDiscountPct   Decimal? @db.Decimal(5, 2)

  platform          String?
  platformFollowers Int?
  categoryFocus     String?
  applicationNote   String?

  adminNote  String?
  approvedAt DateTime?
  approvedBy String?

  payoutMethod  AffiliatePayoutMethod?
  payoutDetails String?

  totalConversions   Int     @default(0)
  totalEarnedEgp     Decimal @default(0) @db.Decimal(12, 2)
  pendingEarningsEgp Decimal @default(0) @db.Decimal(12, 2)

  commissions      Commission[]
  referralsMade    AffiliateReferral[] @relation("ReferrerAffiliate")
  referredBy       AffiliateReferral?  @relation("ReferredAffiliate")
  bonuses          AffiliateBonus[]
  affiliatePayouts AffiliatePayout[]
  promoUsages      PromoCodeUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([tier])
  @@index([promoCode])
}

model AffiliateTierConfig {
  id             String        @id @default(uuid())
  tier           AffiliateTier @unique
  name           String
  minConversions Int
  commissionPct  Decimal       @db.Decimal(5, 2)
  isActive       Boolean       @default(true)
  updatedAt      DateTime      @updatedAt
}

model AffiliateGlobalSettings {
  id                 String   @id @default("global")
  defaultDiscountPct Decimal  @default(15) @db.Decimal(5, 2)
  maxDiscountPct     Decimal  @default(30) @db.Decimal(5, 2)
  referrerBonusEgp   Decimal  @default(50) @db.Decimal(10, 2)
  joinerBonusEgp     Decimal  @default(30) @db.Decimal(10, 2)
  bonusExpiryDays    Int      @default(90)
  bonusesEnabled     Boolean  @default(true)
  programEnabled     Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  updatedBy          String?
}

model PromoCodeUsage {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id])
  buyerId     String
  buyer       User      @relation("BuyerPromoUsages", fields: [buyerId], references: [id])

  discountPct              Decimal @db.Decimal(5, 2)
  discountAmountEgp        Decimal @db.Decimal(10, 2)
  orderTotalBeforeDiscount Decimal @db.Decimal(10, 2)
  orderTotalAfterDiscount  Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([affiliateId])
  @@index([buyerId])
}

model Commission {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id])

  orderTotalEgp Decimal @db.Decimal(10, 2)
  commissionPct Decimal @db.Decimal(5, 2)
  commissionEgp Decimal @db.Decimal(10, 2)

  status      AffiliateCommissionStatus @default(PENDING)
  confirmedAt DateTime?
  paidAt      DateTime?
  payoutId    String?
  payout      AffiliatePayout?          @relation(fields: [payoutId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([affiliateId, status])
  @@index([orderId])
}

model AffiliateReferral {
  id                  String    @id @default(uuid())
  referrerAffiliateId String
  referrer            Affiliate @relation("ReferrerAffiliate", fields: [referrerAffiliateId], references: [id])

  newAffiliateId String    @unique
  newAffiliate   Affiliate @relation("ReferredAffiliate", fields: [newAffiliateId], references: [id])

  referrerBonusId String?         @unique
  referrerBonus   AffiliateBonus? @relation("ReferrerBonus", fields: [referrerBonusId], references: [id])
  joinerBonusId   String?         @unique
  joinerBonus     AffiliateBonus? @relation("JoinerBonus", fields: [joinerBonusId], references: [id])

  firstOrderTriggered Boolean @default(false)
  firstOrderId        String?

  createdAt DateTime @default(now())

  @@index([referrerAffiliateId])
}

model AffiliateBonus {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])

  type      AffiliateBonusType
  amountEgp Decimal              @db.Decimal(10, 2)
  status    AffiliateBonusStatus @default(PENDING)

  expiresAt     DateTime?
  activatedAt   DateTime?
  usedAt        DateTime?
  usedOnOrderId String?

  referralAsReferrer AffiliateReferral? @relation("ReferrerBonus")
  referralAsJoiner   AffiliateReferral? @relation("JoinerBonus")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([affiliateId, status])
}

model AffiliatePayout {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])

  amountEgp     Decimal               @db.Decimal(10, 2)
  method        AffiliatePayoutMethod
  payoutDetails String
  status        AffiliatePayoutStatus @default(REQUESTED)

  commissions Commission[]
  adminNote   String?
  processedBy String?
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([affiliateId, status])
}

model HomepageBanner {
  id        String    @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String
  ctaLabel  String?
  position  Int       @default(0)
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, position])
}

// ============================================================
// ADMIN CONTROL-PANEL MODELS
// ============================================================
// These models back the Shopify-style admin control panel.
// See ADMIN_PLAN.md for the full inventory of which tabs read/write what.

// CMS pages — About / FAQ / Terms / Privacy / Returns / Contact / etc.
// Slug-addressable, bilingual, with revision tracking via updatedAt.
model Page {
  id             String     @id @default(uuid())
  slug           String     @unique
  // Public title rendered in <h1> + the meta <title> when seoTitle is empty.
  titleEn        String
  titleAr        String?
  // Markdown body. We render via a sanitized markdown parser so authors
  // can use formatting without an XSS surface.
  bodyEn         String     @db.Text
  bodyAr         String?    @db.Text
  seoTitle       String?
  seoDescription String?
  ogImageUrl     String?
  // DRAFT pages aren't reachable at /p/<slug>; PUBLISHED ones are.
  status         PageStatus @default(PUBLISHED)
  // Optional positions in the footer / nav. 0 = not shown.
  footerOrder    Int        @default(0)
  navOrder       Int        @default(0)
  createdBy      String? // User.id of the admin who created it
  updatedBy      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status])
  @@index([slug, status])
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Editable transactional + marketing email templates. The admin can
// override any built-in template here without redeploying. The
// `key` is what `src/lib/email.ts` looks up; if no row exists, the
// hard-coded default in code wins.
model EmailTemplate {
  id         String    @id @default(uuid())
  key        String    @unique // e.g. "order_confirmation", "rma_approved"
  // Subject + body in both languages. Template variables use
  // `{{var_name}}` syntax (e.g. `{{order.id}}`, `{{user.firstName}}`).
  subjectEn  String
  subjectAr  String?
  bodyEn     String    @db.Text
  bodyAr     String?   @db.Text
  // Whitelist of variables the template is allowed to reference; used
  // by the editor's auto-complete and the runtime sanitizer.
  variables  String?   @db.Text // JSON array
  // Whether this template is sent at all. Set false to globally disable
  // (e.g. abandoned-cart while we troubleshoot deliverability).
  isActive   Boolean   @default(true)
  // Last test-send timestamp + recipient, surfaced in the editor.
  lastTestAt DateTime?
  lastTestTo String?
  updatedBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([key])
}

// Marketing campaigns — manual or scheduled blasts via email/push/SMS.
// One row per campaign. Stats are denormalized counters that the
// delivery worker bumps as the queue drains.
model MarketingCampaign {
  id             String          @id @default(uuid())
  name           String
  description    String?
  channel        CampaignChannel
  // Audience selector — JSON DSL: `{ "role": "BUYER", "lastOrderDays": 30 }`.
  // The send worker translates this into a Prisma where-clause.
  audienceJson   String          @db.Text
  // Subject (email), title (push), or 160-char body (SMS).
  subject        String?
  body           String          @db.Text
  ctaUrl         String?
  // Optional reference to an EmailTemplate key — when set, the worker
  // uses the template's body and variables, with this row's `body` as
  // an override.
  templateKey    String?
  // Scheduling. status=DRAFT until scheduled or sent.
  scheduledAt    DateTime?
  sentAt         DateTime?
  status         CampaignStatus  @default(DRAFT)
  // Live counters.
  recipientCount Int             @default(0)
  sentCount      Int             @default(0)
  openCount      Int             @default(0)
  clickCount     Int             @default(0)
  failCount      Int             @default(0)
  createdBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status, scheduledAt])
  @@index([channel])
}

enum CampaignChannel {
  EMAIL
  PUSH
  SMS
  IN_APP
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

// Third-party integrations / plugins. The env-var driven registry in
// help.txt and AGENTS.md is what's available; this table tracks
// per-plugin enabled state, the masked secrets/IDs, and the last
// connection-test result so admin can see at a glance which plugins are
// healthy.
model Plugin {
  id          String         @id @default(uuid())
  // Stable slug — see PLUGIN_REGISTRY in lib/plugin-registry.ts for the
  // canonical list. Examples: "stripe", "paysky", "ga4", "crisp".
  slug        String         @unique
  // Display name + the category we group it under in the admin UI.
  name        String
  category    PluginCategory
  isEnabled   Boolean        @default(false)
  // Free-form config — usually `{ apiKey, webhookSecret, … }`. Secrets
  // here are AES-256-GCM encrypted via lib/secrets.ts.
  configJson  String         @db.Text
  // Connection-test status + the last successful ping. Both are bumped
  // by `POST /api/admin/plugins/[slug]/test`.
  lastTestOk  Boolean?
  lastTestAt  DateTime?
  lastTestMsg String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

enum PluginCategory {
  PAYMENT
  ANALYTICS
  CHAT
  EMAIL
  STORAGE
  PUSH
  SHIPPING
  SMS
  ADS
  OTHER
}

// Per-governorate (or per-zone) shipping rate. Replaces the hard-coded
// constants in lib/shipping-rates.ts. The lookup function reads here
// first and falls back to the SHIPPING_RATES_JSON setting only if the
// table is empty (fresh install).
model ShippingZone {
  id              String   @id @default(uuid())
  name            String // "Greater Cairo + Alexandria"
  // CSV of governorate names that fall in this zone (lowercased on read).
  governorates    String   @db.Text
  // Flat rate in EGP. Overridden by per-weight bands when set.
  rateEgp         Decimal  @db.Decimal(10, 2)
  // Optional weight bands — JSON: `[{maxGrams:1000, rate:60}, ...]`.
  weightBandsJson String?  @db.Text
  // Optional courier — used to populate seller's preferred-courier
  // dropdown and the public store delivery promise.
  defaultCourier  String?
  // Estimated transit time, surfaced on the cart/checkout page.
  estDaysMin      Int?
  estDaysMax      Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

// Per-category VAT override. The default 14% rate lives in the
// SystemSettings catalog (key=VAT_RATE); admin can override by category
// here for goods that have reduced or exempt rates (e.g. medicine 0%,
// books 5%).
model TaxRate {
  id          String       @id @default(uuid())
  // Either categoryId (most common) OR `appliesTo='ALL'` for the global
  // default override. exactly one is required at the DB level via the
  // unique constraint below.
  categoryId  String?
  appliesTo   TaxAppliesTo @default(CATEGORY)
  rate        Decimal      @db.Decimal(5, 4) // e.g. 0.1400 for 14%
  label       String // "VAT" / "Reduced VAT" / "Exempt"
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([categoryId, appliesTo])
}

enum TaxAppliesTo {
  ALL // global override
  CATEGORY
  PRODUCT // future
}

// Multi-currency support. The default currency lives in the settings
// registry as STORE_CURRENCY (default "EGP"); additional rows here
// power the currency switcher. FX rate is base-currency relative.
model Currency {
  code      String   @id // ISO-4217: "EGP", "USD", "EUR"
  name      String // "Egyptian Pound"
  symbol    String // "ج.م", "$", "€"
  // Multiplier vs the base currency (EGP). 1 EGP = X currency.
  fxRate    Decimal  @db.Decimal(12, 6)
  // Decimal places to show; some currencies (JPY, EGP for daily UI) use 0.
  decimals  Int      @default(2)
  isActive  Boolean  @default(true)
  // Display order in the picker.
  position  Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Granular permission catalog. Initial seed: the canonical operations
// across each tab. Custom roles let the admin assemble permissions into
// named sets and assign them to users — beyond the 3-value enum.
model Permission {
  id          String   @id @default(uuid())
  // Slug — e.g. "products.read", "orders.update", "users.delete".
  slug        String   @unique
  // Human-friendly name and the tab it belongs to.
  name        String
  category    String
  description String?
  createdAt   DateTime @default(now())

  roles AdminRolePermission[]
}

model AdminRole {
  id          String   @id @default(uuid())
  slug        String   @unique // "content_editor", "support_agent"
  name        String
  description String?
  // Built-in roles can't be deleted from the UI.
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  permissions AdminRolePermission[]
  users       UserAdminRole[]
}

model AdminRolePermission {
  roleId       String
  permissionId String
  role         AdminRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserAdminRole {
  userId    String
  roleId    String
  // Audit: who granted this role and when.
  grantedBy String?
  grantedAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

// Abandoned-cart re-engagement. We snapshot a guest's or buyer's cart
// when they leave checkout-stage page, then a worker picks rows older
// than ABANDONED_CART_DELAY_HOURS and triggers the abandoned-cart email
// template. Status flips to RECOVERED once the cart turns into an Order.
model AbandonedCart {
  id               String              @id @default(uuid())
  // Either userId OR guestEmail is set.
  userId           String?
  guestEmail       String?
  // Snapshot of cart contents — JSON of { variantId, quantity, price }.
  itemsJson        String              @db.Text
  totalEgp         Decimal             @db.Decimal(10, 2)
  status           AbandonedCartStatus @default(PENDING)
  emailSentAt      DateTime?
  recoveredAt      DateTime?
  recoveredOrderId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

enum AbandonedCartStatus {
  PENDING // awaiting send
  EMAILED // reminder sent
  RECOVERED // user came back & ordered
  EXPIRED // ignored long enough we stopped trying
}
