generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & ROLES
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  name              String
  role              Role      @default(BUYER)
  phone             String?
  avatarUrl         String?
  defaultAddressId  String?
  loyaltyPoints     Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  orders            Order[]
  addresses         Address[]
  reviews           Review[]
  wishlist          Wishlist[]
  emailVerified     DateTime?
  cart              CartItem[]
  sellerProfile     SellerProfile?
  passwordResetTokens PasswordResetToken[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  productQAs        ProductQA[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  user      User     @relation(fields: [email], references: [email], onDelete: Cascade)

  @@unique([email, token])
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  street      String
  city        String
  governorate String
  postalCode  String?
  country     String   @default("Egypt")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// SELLERS & PORTAL
// ============================================

model SellerProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  storeName         String   @unique
  description       String?
  logoUrl           String?
  city              String?
  governorate       String?
  commissionRate    Float    @default(0.15) // Platform takes 15%
  status            SellerStatus @default(PENDING_APPROVAL)
  bankAccount       String?
  balance           Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products          Product[]
  payouts           Payout[]
}

enum SellerStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  BANNED
}

// ============================================
// CATALOGUE & INVENTORY
// ============================================

model Product {
  id                String    @id @default(uuid())
  sellerId          String
  categoryId        String
  title             String
  slug              String    @unique
  description       String
  basePrice         Float     // In EGP
  condition         String    @default("NEW")
  isFeatured        Boolean   @default(false)
  weightGrams       Int?
  published         Boolean   @default(true)
  
  // Flash Sale
  flashSalePrice    Float?
  flashSaleEndsAt   DateTime?
  flashSaleLimit    Int?

  // Local Verification
  countryOfOrigin   String    @default("Egypt")
  isVerifiedLocal   Boolean   @default(false)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  seller            SellerProfile @relation(fields: [sellerId], references: [id])
  category          Category      @relation(fields: [categoryId], references: [id])
  variants          ProductVariant[]
  images            ProductImage[]
  reviews           Review[]
  wishlistedBy      Wishlist[]
  tags              Tag[]
  collections       Collection[]
  productQAs        ProductQA[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  parentId    String?
  parent      Category? @relation("Subcategories", fields: [parentId], references: [id])
  children    Category[] @relation("Subcategories")
  products    Product[]
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique

  products Product[]
}

model Collection {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  imageUrl    String?

  products Product[]
}

model ProductVariant {
  id          String    @id @default(uuid())
  productId   String
  sku         String    @unique
  title       String    // e.g. "Red - Medium"
  attributes  String    // JSON string for colors/sizes
  price       Float     // Specific variant price overriding basePrice if needed
  stockCount  Int       @default(0)

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

model ProductImage {
  id          String  @id @default(uuid())
  productId   String
  url         String
  isPrimary   Boolean @default(false)
  
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================
// CART & CHECKOUT
// ============================================

model CartItem {
  id          String   @id @default(uuid())
  userId      String   
  variantId   String
  quantity    Int
  savedPrice  Float
  addedAt     DateTime @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  @@unique([userId, variantId])
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  discountType    DiscountType
  discountValue   Float
  minOrderValue   Float?
  maxDiscount     Float?
  expiryDate      DateTime
  usageLimit      Int?
  usedCount       Int      @default(0)
  isActive        Boolean  @default(true)

  orders          Order[]
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ============================================
// ORDERS & LIFECYCLE
// ============================================

model Order {
  id                  String   @id @default(uuid())
  userId              String?
  guestEmail          String?
  couponId            String?
  totalAmount         Float
  discountAmount      Float    @default(0)
  shippingFee         Float    @default(0)
  platformFee         Float    @default(0)
  sellerPayoutTotal   Float    @default(0)
  status              OrderStatus @default(PENDING_PAYMENT)
  paymentMethod       PaymentMethod
  paymentStatus       PaymentStatus @default(UNPAID)
  paymentId           String?  // Gateway ID (Stripe/Paymob/PaySky SystemReference)
  paymentChannel      String?  // Network used (e.g. Card / Tahweel / mVisa / Meeza)
  paymentNetworkRef   String?  // Network-side reference (e.g. PaySky NetworkReference)
  paymentMaskedPan    String?  // Masked card / wallet account for receipts
  idempotencyKey      String?  @unique
  payoutProcessedAt   DateTime? // Guard against double-payout

  // Customer checkout options
  orderNotes          String?  // Optional buyer instructions (max 500 chars)
  giftWrapping        Boolean  @default(false)
  
  // Snapshots for historical integrity
  shippingAddressSnapshot String  // JSON string of address
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  // Set when the order transitions to DELIVERED. Used to gate seller-earnings
  // escrow: payouts are held for ESCROW_DAYS (14) after delivery so any
  // returns/refunds don't leak through. Falls back to updatedAt when null
  // for orders delivered before this field was added.
  deliveredAt         DateTime?

  user                User?     @relation(fields: [userId], references: [id])
  coupon              Coupon?  @relation(fields: [couponId], references: [id])
  items               OrderItem[]
  shipments           Shipment[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  variantId       String
  
  // Snapshots
  productTitleSnapshot String
  sellerNameSnapshot   String
  priceAtPurchase      Float
  quantity             Int

  status          OrderItemStatus @default(PENDING) // Can be refunded/returned individually

  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  returnRequest   ReturnRequest?
}

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum OrderItemStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  MOBILE_WALLET
  CASH_ON_DELIVERY
  PAYMOB
  FAWRY
  PAYSKY
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ============================================
// SHIPPING & TRANSACTIONS
// ============================================

model Shipment {
  id              String   @id @default(uuid())
  orderId         String
  trackingNumber  String?
  courier         String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============================================
// TRUST & SOCIAL
// ============================================

model Review {
  id                  String   @id @default(uuid())
  userId              String
  productId           String
  rating              Int      // 1-5
  comment             String?
  images              String[] @default([])
  verifiedPurchase    Boolean  @default(false)
  sellerResponseText  String?
  createdAt           DateTime @default(now())

  user                User     @relation(fields: [userId], references: [id])
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================
// PRODUCT Q&A
// ============================================

model ProductQA {
  id          String   @id @default(uuid())
  productId   String
  userId      String
  question    String
  answer      String?
  answererId  String?
  answeredAt  DateTime?
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([productId])
}

// ============================================
// SYSTEM & AUDIT
// ============================================

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payout {
  id              String       @id @default(uuid())
  sellerId        String
  amount          Float
  status          PayoutStatus @default(PENDING)
  bankDetails     String?
  transactionId   String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())

  seller          SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
}

model ReturnRequest {
  id            String       @id @default(uuid())
  orderItemId   String       @unique
  reason        String
  details       String?
  status        ReturnStatus @default(PENDING)
  adminNotes    String?
  createdAt     DateTime     @default(now())

  orderItem     OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String   // e.g. "BANNED_SELLER"
  targetId    String?
  details     String?
  createdAt   DateTime @default(now())

  admin       User     @relation(fields: [adminId], references: [id])
}

model SystemSettings {
  key         String   @id // e.g. "VAT_RATE", "COMMISSION_BASE"
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Wishlist {
  userId      String
  productId   String
  addedAt     DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
}

// ============================================
// DISPUTES
// ============================================

model Dispute {
  id            String       @id @default(uuid())
  orderId       String
  orderItemId   String?
  buyerId       String
  sellerId      String?
  reason        String
  description   String?
  status        DisputeStatus @default(OPEN)
  resolution    String?
  resolvedAt    DateTime?
  caseReference String       @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([orderId])
  @@index([buyerId])
  @@index([status])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

// ============================================
// CHAT / CONVERSATIONS
// ============================================

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  productId String?
  orderId   String?
  status    ConversationStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Message[]

  @@index([userId])
  @@index([status])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  role           String   @default("USER")
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum ConversationStatus {
  ACTIVE
  CLOSED
}

// ============================================
// SUPPORT TICKETS
// ============================================

model SupportTicket {
  id          String        @id @default(uuid())
  ticketId    String        @unique // Short human-readable reference
  userId      String?
  name        String
  email       String
  subject     String
  category    String        @default("general")
  message     String
  status      TicketStatus  @default(OPEN)
  priority    String        @default("normal")
  adminReply  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ============================================
// CMS: HOMEPAGE BANNERS
// ============================================

model HomepageBanner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  imageUrl    String
  linkUrl     String
  ctaLabel    String?
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, position])
}
