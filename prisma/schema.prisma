generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & ROLES
// ============================================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  name              String
  role              Role      @default(BUYER)
  phone             String?
  avatarUrl         String?
  defaultAddressId  String?
  loyaltyPoints     Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  orders            Order[]
  addresses         Address[]
  reviews           Review[]
  wishlist          Wishlist[]
  emailVerified     DateTime?
  cart              CartItem[]
  sellerProfile     SellerProfile?
  passwordResetTokens PasswordResetToken[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  productQAs        ProductQA[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  user      User     @relation(fields: [email], references: [email], onDelete: Cascade)

  @@unique([email, token])
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  street      String
  city        String
  governorate String
  postalCode  String?
  country     String   @default("Egypt")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// SELLERS & PORTAL
// ============================================

model SellerProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  storeName         String   @unique
  description       String?
  logoUrl           String?
  commissionRate    Float    @default(0.15) // Platform takes 15%
  status            SellerStatus @default(PENDING_APPROVAL)
  bankAccount       String?
  balance           Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products          Product[]
  payouts           Payout[]
}

enum SellerStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  BANNED
}

// ============================================
// CATALOGUE & INVENTORY
// ============================================

model Product {
  id                String    @id @default(uuid())
  sellerId          String
  categoryId        String
  title             String
  slug              String    @unique
  description       String
  basePrice         Float     // In EGP
  condition         String    @default("NEW")
  isFeatured        Boolean   @default(false)
  weightGrams       Int?
  published         Boolean   @default(true)
  
  // Flash Sale
  flashSalePrice    Float?
  flashSaleEndsAt   DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  seller            SellerProfile @relation(fields: [sellerId], references: [id])
  category          Category      @relation(fields: [categoryId], references: [id])
  variants          ProductVariant[]
  images            ProductImage[]
  reviews           Review[]
  wishlistedBy      Wishlist[]
  tags              Tag[]
  collections       Collection[]
  productQAs        ProductQA[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  parentId    String?
  parent      Category? @relation("Subcategories", fields: [parentId], references: [id])
  children    Category[] @relation("Subcategories")
  products    Product[]
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique

  products Product[]
}

model Collection {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  imageUrl    String?

  products Product[]
}

model ProductVariant {
  id          String    @id @default(uuid())
  productId   String
  sku         String    @unique
  title       String    // e.g. "Red - Medium"
  attributes  String    // JSON string for colors/sizes
  price       Float     // Specific variant price overriding basePrice if needed
  stockCount  Int       @default(0)

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

model ProductImage {
  id          String  @id @default(uuid())
  productId   String
  url         String
  isPrimary   Boolean @default(false)
  
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================
// CART & CHECKOUT
// ============================================

model CartItem {
  id          String   @id @default(uuid())
  userId      String   
  variantId   String
  quantity    Int
  savedPrice  Float
  addedAt     DateTime @default(now())

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  @@unique([userId, variantId])
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique
  discountType    DiscountType
  discountValue   Float
  minOrderValue   Float?
  maxDiscount     Float?
  expiryDate      DateTime
  usageLimit      Int?
  usedCount       Int      @default(0)
  isActive        Boolean  @default(true)

  orders          Order[]
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ============================================
// ORDERS & LIFECYCLE
// ============================================

model Order {
  id                  String   @id @default(uuid())
  userId              String?
  guestEmail          String?
  couponId            String?
  totalAmount         Float
  discountAmount      Float    @default(0)
  shippingFee         Float    @default(0)
  status              OrderStatus @default(PENDING_PAYMENT)
  paymentMethod       PaymentMethod
  paymentStatus       PaymentStatus @default(UNPAID)
  paymentId           String?  // Gateway ID (Stripe/Paymob)
  idempotencyKey      String?  @unique
  
  // Snapshots for historical integrity
  shippingAddressSnapshot String  // JSON string of address
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User?     @relation(fields: [userId], references: [id])
  coupon              Coupon?  @relation(fields: [couponId], references: [id])
  items               OrderItem[]
  shipments           Shipment[]
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  variantId       String
  
  // Snapshots
  productTitleSnapshot String
  sellerNameSnapshot   String
  priceAtPurchase      Float
  quantity             Int

  status          OrderItemStatus @default(PENDING) // Can be refunded/returned individually

  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id])
  returnRequest   ReturnRequest?
}

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum OrderItemStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  MOBILE_WALLET
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

// ============================================
// SHIPPING & TRANSACTIONS
// ============================================

model Shipment {
  id              String   @id @default(uuid())
  orderId         String
  trackingNumber  String?
  courier         String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ============================================
// TRUST & SOCIAL
// ============================================

model Review {
  id                  String   @id @default(uuid())
  userId              String
  productId           String
  rating              Int      // 1-5
  comment             String?
  verifiedPurchase    Boolean  @default(false)
  sellerResponseText  String?
  createdAt           DateTime @default(now())

  user                User     @relation(fields: [userId], references: [id])
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================
// PRODUCT Q&A
// ============================================

model ProductQA {
  id          String   @id @default(uuid())
  productId   String
  userId      String
  question    String
  answer      String?
  answererId  String?
  answeredAt  DateTime?
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([productId])
}

// ============================================
// SYSTEM & AUDIT
// ============================================

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payout {
  id              String       @id @default(uuid())
  sellerId        String
  amount          Float
  status          PayoutStatus @default(PENDING)
  bankDetails     String?
  transactionId   String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())

  seller          SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
}

model ReturnRequest {
  id            String       @id @default(uuid())
  orderItemId   String       @unique
  reason        String
  details       String?
  status        ReturnStatus @default(PENDING)
  adminNotes    String?
  createdAt     DateTime     @default(now())

  orderItem     OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String   // e.g. "BANNED_SELLER"
  targetId    String?
  details     String?
  createdAt   DateTime @default(now())

  admin       User     @relation(fields: [adminId], references: [id])
}

model SystemSettings {
  key         String   @id // e.g. "VAT_RATE", "COMMISSION_BASE"
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Wishlist {
  userId      String
  productId   String
  addedAt     DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
}
