# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# next-pwa generated files (regenerated by `next build`)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel
/src/generated/client

# typescript
*.tsbuildinfo
next-env.d.ts

# Local SQLite from earlier dev (project now uses Postgres on Neon)
prisma/dev.db
prisma/*.db-journal

# Dev scratch / notes / preview assets
/scratch
/tmp
/Affiliate
/hidden-model-ai
last
mazen.txt
stitch-preview.png


# Reserved Windows filename that occasionally gets created by stray
# stdout redirections (`> nul`). It cannot be removed on Windows so we
# just keep it out of the index.
nul

# Playwright reports and results
/playwright-report
/test-results
.env*.local
emails.log
